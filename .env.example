# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_OWNER_ID=123456789
TELEGRAM_CHANNEL_ID=@your_channel

# Ozon Seller API
OZON_CLIENT_ID=replace_me
OZON_API_KEY=replace_me
OZON_BASE_URL=https://api-seller.ozon.ru

# Ollama: install Ollama locally and run `ollama pull qwen2.5:7b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_PREDICT=650

# App
DATABASE_URL=sqlite:///data/bot.sqlite3
APP_MODE=manual
POST_STYLE=premium
POST_INTERVAL_MINUTES=360
MAX_PRODUCTS_PER_SYNC=20
MAX_PHOTOS_PER_POST=1
DRY_RUN=false
LOG_LEVEL=INFO

# Web admin panel
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=change_me
WEB_SESSION_SECRET=change_me_to_long_random_string
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Ozon sync
OZON_VISIBILITY=VISIBLE

# Premium image generation
IMAGE_ENGINE=none
COMFYUI_BASE_URL=http://127.0.0.1:8188
